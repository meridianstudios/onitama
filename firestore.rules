rules_version = '2';

// Onitama Firestore rules — this project holds exactly one collection.
//
// Players are ANONYMOUS auth users (enable Anonymous sign-in in the
// console) — no accounts. Doc id = 6-char room code. Host creates the room;
// one guest may claim the empty seat; after that only the two seated
// players can write. The client validates legal moves; rules enforce seat
// ownership and impersonation prevention.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    match /onitama_rooms/{roomId} {
      // Reading requires knowing the code (spectating via a shared link is fine).
      allow read: if signedIn();

      // Create: you must seat yourself as host with an open guest seat.
      allow create: if signedIn() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.guestUid == null;

      // Update: a seated player moving, or a newcomer claiming the empty
      // guest seat (must stamp their own uid and can't touch the host seat).
      allow update: if signedIn() && (
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid == resource.data.guestUid ||
        (resource.data.guestUid == null &&
         request.resource.data.guestUid == request.auth.uid &&
         request.resource.data.hostUid == resource.data.hostUid)
      );

      // Delete: either seated player (cancel / clear a finished game).
      allow delete: if signedIn() && (
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid == resource.data.guestUid
      );
    }

    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
